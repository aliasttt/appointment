# Example nginx config for RandevuPro (heryerrandevu.com.tr).
# Add the location blocks below INSIDE your existing server { } for this domain.
# Port 8000: change if your app (gunicorn/uwsgi) uses another port.

# --- REQUIRED: serve admin/static files (fixes broken admin login page) ---
# Add this BEFORE your "location /" block:
location /static/ {
    alias /srv/appointment/staticfiles/;
}

# --- Main app proxy (you likely already have this) ---
location / {
    proxy_pass http://127.0.0.1:8000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
