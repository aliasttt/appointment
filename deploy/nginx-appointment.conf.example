# Example nginx config for RandevuPro (heryerrandevu.com.tr).
# Copy to /etc/nginx/sites-available/ and symlink to sites-enabled, or include in your server block.

# Optional: if you want nginx to serve static files instead of the app (faster).
# Add this block INSIDE your server { } for heryerrandevu.com.tr, BEFORE "location /":
#
#   location /static/ {
#       alias /srv/appointment/staticfiles/;
#   }
#
# Then: sudo nginx -t && sudo systemctl reload nginx

# Main app (required):
#   location / {
#       proxy_pass http://127.0.0.1:8000;   # or your gunicorn/uwsgi port
#       proxy_set_header Host $host;
#       proxy_set_header X-Real-IP $remote_addr;
#       proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#       proxy_set_header X-Forwarded-Proto $scheme;
#   }
