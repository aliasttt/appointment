# RandevuPro - Ortam değişkenleri örneği
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.

# Django
DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Veritabanı (varsayılan: SQLite)
# PostgreSQL kullanmak için aşağıdakileri ayarlayın:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=randevupro
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# CORS (API için; boş bırakırsanız tüm originlere izin verilir)
# CORS_ALLOWED_ORIGINS=https://myapp.com,https://www.myapp.com
